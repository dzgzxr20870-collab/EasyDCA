# ===== LINE =====
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
# LINE_NOTIFY_TOKEN — ปิดบริการแล้ว (LINE Notify Shutdown) ไม่ต้องตั้งค่า
LIFF_ID=your_liff_id_here
# line_user_id ของ Admin คั่นด้วย ',' — รับ Push แจ้งคำขอชำระเงินใหม่ + Critical
# Alert (/health ล่ม, Nightly Backup ล้มเหลว)
ADMIN_LINE_USER_IDS=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Supabase =====
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# ===== Authentication =====
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters
JWT_EXPIRES_IN=24h

# ===== Application =====
APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# ===== Market Data (หุ้นสหรัฐ) =====
# Twelve Data API Key — ดึงราคาหุ้นสหรัฐ (stock_us) + อัตราแลกเปลี่ยน USD/THB
# สมัคร Free Tier ที่ https://twelvedata.com (ยังไม่ตั้งค่าได้ — หุ้นสหรัฐจะคืน null)
# TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# ===== Claude API (Phase 4 only) =====
# CLAUDE_API_KEY=your_claude_api_key_here

# ===== Nightly Backup (Cloudflare R2) — ตั้งค่าเฉพาะ Service easydca-worker =====
# Cloudflare Dashboard → R2 → Manage API Tokens (Object Read & Write) — ต้องตั้งครบ
# ทั้ง 4 ตัวถึงจะเริ่ม Backup ได้จริง (ไม่ตั้ง = ข้ามรอบ + Push แจ้ง Admin แทน Crash)
# R2_ACCOUNT_ID=your_cloudflare_account_id_here
# R2_ACCESS_KEY_ID=your_r2_access_key_id_here
# R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
# R2_BUCKET_NAME=easydca-db-backups
# BACKUP_RETENTION_DAYS=14
#
# ----- Client-side Encryption Key (บังคับ ถ้าจะให้ Backup ทำงาน) -----
# ไฟล์ Backup เข้ารหัส AES-256-GCM ก่อนออกจาก Server เสมอ (มีข้อมูลส่วนบุคคลของผู้ใช้
# อยู่ข้างใน) — ไม่ตั้งค่าตัวนี้ = ข้ามรอบ Backup ทั้งรอบ ไม่มีการอัปโหลดแบบไม่เข้ารหัส
# เป็น Fallback เด็ดขาด
#
# Generate Key ใหม่ (Hex 64 ตัวอักษร = 32 Bytes):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# ⚠️⚠️ Key นี้หาย = กู้คืน Backup เก่าทั้งหมด "ไม่ได้เลยตลอดกาล" (Brute-force AES-256
# ไม่มีทางทำได้จริง) — ต้องสำรอง Key ไว้อย่างน้อย 2 ที่ที่แยกจากกัน เช่น Railway
# Variables + Password Manager ส่วนตัว และ "ห้ามเปลี่ยน Key เอง" โดยไม่เก็บ Key เดิมไว้
# ดูรายละเอียดที่ docs/BACKUP_AND_RECOVERY.md § 2.3
# BACKUP_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
